# Gold Market Intelligence — nginx reverse proxy with TLS.
#
# Assumes:
#   - certbot / Let's Encrypt has placed certs at /etc/letsencrypt/live/<domain>/
#   - the backend container exposes 8888 on 127.0.0.1
#   - the SPA static build is served from /var/www/gold-agent/
#
# Hardening:
#   - HSTS preload-eligible header
#   - modern TLS only (1.2 + 1.3)
#   - block clear-text / redirect to HTTPS
#   - tight body size so the backend's upload endpoints aren't abused
#
# Copy this file to /etc/nginx/sites-available/gold-agent.conf, replace
# <your-domain> with your actual domain, then:
#     ln -s /etc/nginx/sites-available/gold-agent.conf /etc/nginx/sites-enabled/
#     nginx -t && systemctl reload nginx

# Redirect HTTP -> HTTPS and serve ACME challenges.
server {
    listen 80;
    listen [::]:80;
    server_name <your-domain>;

    # Let's Encrypt http-01 challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name <your-domain>;

    # TLS certs from certbot.
    ssl_certificate     /etc/letsencrypt/live/<your-domain>/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/<your-domain>/privkey.pem;

    # Modern TLS config (mozilla intermediate baseline).
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:GoldAgentSSL:10m;
    ssl_session_tickets off;

    # Security headers.
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "no-referrer" always;
    # CSP for the SPA. Adjust connect-src if you use additional APIs.
    add_header Content-Security-Policy
        "default-src 'self'; \
         script-src 'self'; \
         style-src 'self' 'unsafe-inline'; \
         img-src 'self' data:; \
         connect-src 'self'; \
         frame-ancestors 'none';" always;

    # Limit request body so historical OHLC uploads can't DoS the backend.
    client_max_body_size 10m;

    # Static SPA.
    location / {
        root /var/www/gold-agent;
        try_files $uri /index.html;
    }

    # Backend API (gated by Authorization: Bearer <token> set via API_TOKENS_FILE).
    location /api/ {
        proxy_pass http://127.0.0.1:8888;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Claude analysis calls can take 20-30s; give them room.
        proxy_connect_timeout 10s;
        proxy_read_timeout    90s;
        proxy_send_timeout    90s;

        # Tight rate limit on live-trading endpoints (configure elsewhere):
        #   limit_req zone=api burst=20 nodelay;
    }

    # Dedicated rate limit for future live-order HTTP routes if you add them.
    # The current build keeps live broker execution at the Python adapter layer,
    # so no /api/live/* endpoints are exposed by default.
    # location /api/live/ {
    #     limit_req zone=live burst=2 nodelay;
    #     proxy_pass http://127.0.0.1:8888;
    # }
}
